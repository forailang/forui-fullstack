# Tests do NOT auto-load this file. By default, getDb() falls back to
# sqlite::memory: when DATABASE_URL is unset, so `fai test` runs
# against an in-memory db. Use this file only if you want a file-
# backed test db; load it manually with env.load('.env.testing').
APP_ENV=testing
SERVER_PORT=3041
SERVER_URL=http://localhost:3041
DATABASE_URL=sqlite::memory:
SESSION_SECRET=change-me-testing
